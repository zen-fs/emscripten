{
	"name": "@zenfs/emscripten",
	"version": "1.0.6",
	"description": "Emscripten backend for ZenFS",
	"funding": {
		"type": "individual",
		"url": "https://github.com/sponsors/james-pre"
	},
	"main": "dist/index.js",
	"types": "src/index.ts",
	"keywords": [
		"filesystem",
		"node",
		"storage"
	],
	"type": "module",
	"homepage": "https://github.com/zen-fs/emscripten",
	"author": "James Prevett <jp@jamespre.dev> (https://jamespre.dev)",
	"license": "LGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zen-fs/emscripten.git"
	},
	"bugs": {
		"url": "https://github.com/zen-fs/emscripten/issues"
	},
	"files": [
		"dist",
		"license.md"
	],
	"engines": {
		"node": ">= 18"
	},
	"exports": {
		".": "./dist/index.js",
		"./*": "./dist/*"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint src",
		"build": "tsc -p tsconfig.json",
		"build:docs": "typedoc --out docs --name 'ZenFS Emscripten' src/index.ts",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/emscripten": "^1.40.0",
		"eslint": "^10.1.0",
		"globals": "^16.0.0",
		"prettier": "^3.2.5",
		"typedoc": "^0.28.18",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.58.0"
	},
	"peerDependencies": {
		"@zenfs/core": "^2.4.2",
		"kerium": "^1.3.4"
	}
}
